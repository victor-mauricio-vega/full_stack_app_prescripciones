model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role
  createdAt DateTime @default(now())

  doctor Doctor? @relation("UserDoctor")


  patient Patient? @relation("UserPatient")

  // Recetas que este usuario ha redactado como doctor
  prescriptionsAuthored Prescription[] @relation("AuthoredByUser")

}
